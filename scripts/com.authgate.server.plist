<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.authgate.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/opt/auth-gate/auth-gate</string>
        <string>start</string>
        <string>--foreground</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__HOME__/.auth-gate</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/auth-gate.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/auth-gate.log</string>
</dict>
</plist>
